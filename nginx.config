server {
    server_name preprod.rohowellness.com;
    root /home/ubuntu/jenkins-agent/workspace/roho_preprod_admin_fe/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;

    }

     client_max_body_size 5M;

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/preprod.rohowellness.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/preprod.rohowellness.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

server {
    server_name preprodcore.rohowellness.com;

    location / {
        proxy_pass http://localhost:8081;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }

     client_max_body_size 5M;

    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/preprod.rohowellness.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/preprod.rohowellness.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}

server {
    listen 80;
    server_name preprodnotification.rohowellness.com;

    location / {
        proxy_pass http://localhost:8082;
        proxy_http_version 1.1;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection 'upgrade';
        proxy_set_header Host $host;
        proxy_cache_bypass $http_upgrade;
    }
}


server {
    server_name uat.rohowellness.com;
    root /home/ubuntu/roho_uat_admin_fe/dist;
    index index.html;

    location / {
        try_files $uri $uri/ /index.html;

    }

     client_max_body_size 5M;


    listen 443 ssl; # managed by Certbot
    ssl_certificate /etc/letsencrypt/live/uat.rohowellness.com/fullchain.pem; # managed by Certbot
    ssl_certificate_key /etc/letsencrypt/live/uat.rohowellness.com/privkey.pem; # managed by Certbot
    include /etc/letsencrypt/options-ssl-nginx.conf; # managed by Certbot
    ssl_dhparam /etc/letsencrypt/ssl-dhparams.pem; # managed by Certbot

}





server {
    if ($host = preprod.rohowellness.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name preprod.rohowellness.com;
    return 404; # managed by Certbot


}

server {
    if ($host = preprodcore.rohowellness.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    listen 80;
    server_name preprodcore.rohowellness.com;
    return 404; # managed by Certbot


}



server {
    if ($host = uat.rohowellness.com) {
        return 301 https://$host$request_uri;
    } # managed by Certbot


    server_name uat.rohowellness.com;
    listen 80;
    return 404; # managed by Certbot


}
